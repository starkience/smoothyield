# Privy credentials — get these from dashboard.privy.io → Settings → API Keys
PRIVY_APP_ID=cmm3npboo05370cjr7kp9sbg6
PRIVY_APP_SECRET=your-privy-app-secret-here

# Optional: Privy JWKS URL for server-side JWT verification (Starknet + Privy integration).
# Defaults to https://auth.privy.io/api/v1/apps/<PRIVY_APP_ID>/jwks.json if unset.
# PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/cmm3npboo05370cjr7kp9sbg6/jwks.json

# AVNU paymaster API key — required for gasfree (sponsored) deploy + stake/convert.
# Get from https://portal.avnu.fi — see https://docs.starknet.io/build/starkzap/paymasters
AVNU_PAYMASTER_API_KEY=

# Starknet RPC: Alchemy (recommended). Get key from https://dashboard.alchemy.com
# If set, used for all Starknet reads (balances, deploy check) and SDK.
ALCHEMY_STARKNET_API_KEY=

# Optional: override RPC URL entirely (e.g. https://starknet-mainnet.g.alchemy.com/v2/YOUR_KEY)
# STARKNET_RPC_URL=

# Set to false once you have real Privy credentials
DEV_MODE=true

# BTC/LBTC staking APY (%) shown in the app. Default 3.33 (from Voyager staking dashboard).
# Override to match https://voyager.online/staking-dashboard when it changes.
# BTC_STAKING_APY=3.33

PORT=3000
